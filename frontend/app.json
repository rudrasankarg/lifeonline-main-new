{
  "expo": {
    "name": "lifeOnLine",
    "slug": "lifeOnline",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/new.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/new.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8FAFC"
    },
    "plugins": [
      "@config-plugins/react-native-webrtc",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "lifeOnLine needs your location to send emergency services to you."
        }
      ]
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.lifeonline.ai",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "lifeOnLine needs your location to dispatch emergency services.",
        "NSCameraUsageDescription": "lifeOnLine needs camera access for video consultations.",
        "NSMicrophoneUsageDescription": "lifeOnLine needs microphone access for video consultations."
      },
      "bitcode": false
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/new.png",
        "backgroundColor": "#0D9488"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.lifeline.ai",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "RECORD_AUDIO",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.CAMERA",
        "android.permission.INTERNET",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.RECORD_AUDIO",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.WAKE_LOCK",
        "android.permission.BLUETOOTH",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/new.png",
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "f5047ebb-246e-4bbe-b203-e3e0b4ab9b13"
      }
    }
  }
}
